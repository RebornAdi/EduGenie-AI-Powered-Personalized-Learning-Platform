{
  "name": "edugenie",
  "private": true,
  "version": "1.0.0",
  "description": "NPM-first local workflow for the EduGenie full-stack app.",
  "scripts": {
    "setup": "npm --prefix frontend install && npm run setup:backend",
    "setup:backend": "node scripts/setup-backend.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:backend": "node scripts/dev-backend.mjs",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint"
  },
  "engines": {
    "node": ">=18"
  }
}
